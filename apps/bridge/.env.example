# Robot Bridge configuration (copy to .env) — MQTT → ESP32

# --- MQTT broker -----------------------------------------------------------
# Where to publish commands. Point this at your broker once it's set up.
#   local Mosquitto:   localhost:1883
#   public test:       broker.hivemq.com:1883  (no auth)
BRIDGE_MQTT_HOST=localhost
BRIDGE_MQTT_PORT=1883
BRIDGE_MQTT_USERNAME=
BRIDGE_MQTT_PASSWORD=
BRIDGE_MQTT_TLS=0              # 1 to use TLS (e.g. HiveMQ Cloud on 8883)
BRIDGE_MQTT_CLIENT_ID=speech-to-action-bridge
BRIDGE_MQTT_KEEPALIVE=60
BRIDGE_MQTT_QOS=1

# Topics the ESP32 subscribes to
BRIDGE_MQTT_TOPIC_COMMANDS=robot/commands
BRIDGE_MQTT_TOPIC_STOP=robot/stop

# --- Movement normalization (JSON → time-based for the ESP32 car) ----------
BRIDGE_MAX_DURATION=10         # clamp seconds per step (safety)
BRIDGE_DEFAULT_SPEED_PCT=60    # speed % used when a command omits "speed"
BRIDGE_ROT_PER_SEC=1.0         # approx degrees/rotations → seconds (no encoder)
