# Robot Bridge configuration (copy to .env)

# Wi-Fi connection mode to the robot:
#   sta = router mode  (robot + laptop on the same Wi-Fi router)
#   ap  = direct mode  (laptop joins the robot's own access point)
BRIDGE_CONN_TYPE=sta

# Movement tunables
BRIDGE_SPEED=0.5          # m/s for forward/backward
BRIDGE_TURN=45            # deg/s for left/right
BRIDGE_MAX_DURATION=10    # hard safety cap (seconds) per step

# Set to 1 to run WITHOUT a robot / without the SDK — commands are only logged.
# Great for developing & testing /execute end-to-end before touching hardware.
BRIDGE_DRY_RUN=1
